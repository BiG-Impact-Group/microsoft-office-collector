# Supabase — client (safe to expose, used by Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Azure / Entra ID — client (public values, safe to expose)
VITE_AZURE_CLIENT_ID=your-azure-app-client-id
VITE_AZURE_TENANT=common
VITE_AZURE_REDIRECT_URI=http://localhost:5173/oauth-callback.html

# Supabase — edge functions only (never in VITE_ vars)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Token encryption — edge functions only.
# 32-byte key, base64-encoded. Generate with: openssl rand -base64 32
# Tokens are AES-256-GCM encrypted app-side before being stored in Postgres.
TOKEN_ENCRYPTION_KEY=your-base64-32-byte-key

# Azure — edge functions only (secret must never reach the browser)
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_CLIENT_SECRET=your-azure-app-client-secret
AZURE_REDIRECT_URI=http://localhost:5173/oauth-callback.html
AZURE_TENANT=common
